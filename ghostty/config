background = #000000
background-opacity = 0.92
background-opacity-cells = true
background-blur = 10

foreground = #e5e7eb

cursor-color = #ffd60a
cursor-text = #000000

selection-background = #403d39
selection-foreground = #e5e7eb

mouse-hide-while-typing = true

font-family = Ingram Mono
font-size = 14

scrollback-limit = 150000000
link-previews = osc8

copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
right-click-action = copy-or-paste

shell-integration = detect
shell-integration-features = cursor,sudo,title

keybind = super+shift+t=new_tab
keybind = super+w=close_surface
keybind = super+r=reload_config
keybind = super+escape=toggle_fullscreen

keybind = super+t=new_split:down
keybind = super+enter=toggle_split_zoom

keybind = cmd+shift+]=next_tab
keybind = cmd+shift+[=previous_tab
keybind = super+]=goto_split:next
keybind = super+[=goto_split:previous

keybind = global:super+`=toggle_quick_terminal

keybind = cmd+/=increase_font_size:2
keybind = cmd+\=decrease_font_size:2
keybind = cmd+'=reset_font_size
